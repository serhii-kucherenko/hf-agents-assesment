HF_USERNAME=ken2ki

# --- Local Ollama (default when not running on a HF Space) ---
USE_OLLAMA=1
OLLAMA_MODEL=qwen3:14b
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_NUM_CTX=16384

# Optional: vision model for image questions (pull first: ollama pull llava:7b)
# OLLAMA_VISION_MODEL=llava:7b

# Optional: local speech-to-text model size (tiny/base/small/medium)
# WHISPER_MODEL=base

# --- Hugging Face cloud (used on Spaces, or when USE_OLLAMA=0) ---
# HF_TOKEN=hf_your_token_here
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_PROVIDER=hf

# Optional overrides
# AGENT_MAX_STEPS=10
# HF_SPACE_ID=ken2ki/Final_Assignment_Template
