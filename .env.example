# Data policy: use course API + eval/fixtures only. Do NOT download gaia-benchmark/GAIA.

HF_USERNAME=your_hf_username

# --- Local llama.cpp + Qwen3-14B GGUF (default) ---
LLM_PROVIDER=llamacpp
LLAMA_CPP_MODEL_REPO=bartowski/Qwen_Qwen3-14B-GGUF
LLAMA_CPP_MODEL_FILE=Qwen3-14B-Q4_K_M.gguf
LLAMA_CPP_MODEL_PATH=./models/qwen3-14b/Qwen3-14B-Q4_K_M.gguf
LLAMA_CPP_MODEL_ID=Qwen3-14B-Q4_K_M
LLAMA_CPP_API_BASE=http://127.0.0.1:8080/v1
LLAMA_CPP_API_KEY=llama
LLAMA_CPP_CTX=16384
# Terminal 1: llama-server -m $LLAMA_CPP_MODEL_PATH --host 127.0.0.1 --port 8080 -c 16384 --jinja

PIPELINE_DEPTH=minimal
CRITIC_MODEL=
BROWSER_ENABLED=0
VOTE_RUNS=1
AGENT_ARTIFACTS=1
RETRIEVER_ENABLED=0
SELF_EVOLVE=0
AGENT_MAX_STEPS=12
EVAL_FIXTURE_MIN_SCORE=80

COURSE_API_URL=https://agents-course-unit4-scoring.hf.space

# --- Hugging Face Space only ---
# HF_TOKEN=hf_your_token_here
# GROQ_API_KEY=gsk_...          # recommended — free tier, bypasses HF inference credits
# GROQ_MODEL=openai/gpt-oss-20b
# LLM_PROVIDER=groq
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_PROVIDER=hf               # uses HF inference (monthly credits; 402 if depleted)

# --- Optional Ollama fallback ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3:14b
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OLLAMA_NUM_CTX=16384

# Think/reasoning: auto (per question), on, or off
THINK_MODE=auto

# Optional: vision model for image questions when not using text-only GGUF
# OLLAMA_VISION_MODEL=llava:7b

# Optional: local speech-to-text model size (tiny/base/small/medium)
# WHISPER_MODEL=base
